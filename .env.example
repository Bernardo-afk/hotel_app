# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://stay:stay@localhost:5432/stay_dev

# ─── Autenticação ─────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# ─── AWS S3 (upload de fotos e vídeos) ───────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=stay-media
AWS_REGION=us-east-1

# ─── Firebase (push notifications FCM) ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=

# ─── Anthropic (OCR de comprovantes) ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── n8n + Z-API (WhatsApp fallback) ─────────────────────────────────────────
N8N_WEBHOOK_URL=
ZAPI_TOKEN=
ZAPI_INSTANCE=

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
